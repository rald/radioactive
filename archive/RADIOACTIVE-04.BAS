1000 REM RADIO ACTIVE
1010 DIM B%(9,9),SX%(99),SY%(99):SP%=100:PX%=0:PY%=0
1020 PRINT CHR$(147);"RADIOACTIVE"
1030 PRINT "PRESS ENTER KEY..."
1040 K=0
1050 K=K+1: GET A$: IF A$<>CHR$(13) THEN 1050
1060 T=RND(-K)
1065 GOSUB 3000
1070 P%=1:GOSUB 9000:GOSUB 3000:GOSUB 4000
1080 P%=2:GOSUB 2000:GOSUB 3000:GOSUB 4000
1090 P%=1:GOSUB 9000:GOSUB 3000:GOSUB 4000
1100 PX%=X%:PY%=Y%
1105 GOSUB 7000:GOSUB 10000:GOSUB 3000:GOSUB 4000
1106 GOSUB 8000:GOSUB 3000:GOSUB 4000
1110 P%=2:GOSUB 2000:GOSUB 3000:GOSUB 4000
1120 PX%=X%:PY%=Y%
1121 GOSUB 7000:GOSUB 10000:GOSUB 3000:GOSUB 4000
1122 GOSUB 8000:GOSUB 3000:GOSUB 4000
1130 GOTO 1090

2000 REM DO MOVE
2010 X%=INT(RND(1)*10)
2020 Y%=INT(RND(1)*10)
2030 IF B%(X%,Y%)<>0 THEN 2010
2040 B%(X%,Y%)=P%
2060 IF P%=2 THEN PRINT "CPU MOVE";X%;Y%: GOSUB 4000
2070 RETURN

3000 REM SHOW BOARD
3010 PRINT CHR$(147);"RADIOACTIVE";CHR$(13);" 0123456789"
3020 FOR J=0 TO 9
3030 PRINT MID$(STR$(J),2);
3040 FOR I=0 TO 9
3050 IF B%(I,J)=0 THEN PRINT ".";
3060 IF B%(I,J)=1 THEN PRINT "O";
3070 IF B%(I,J)=2 THEN PRINT "X";
3080 IF B%(I,J)=3 THEN PRINT "*";
3090 NEXT I
3100 PRINT
3110 NEXT J
3120 PRINT
3130 RETURN

4000 REM SLEEP
4010 FOR D=1 TO 1000:NEXT D
4020 RETURN

7000 REM REACTION
7010 N%=0
7020 FOR L=-1 TO 1
7030 FOR K=-1 TO 1
7040 IF K=0 AND L=0 THEN 7080
7050 X=PX%+K: Y=PY%+L
7060 IF X<0 OR X>9 OR Y<0 OR Y>9 THEN 7080
7070 IF B%(X,Y)<>0 THEN N%=N%+1 
7080 NEXT K
7090 NEXT L
7100 IF N%<3 THEN RETURN
7110 B%(PX%,PY%)=3
7120 RETURN

8000 REM CLEAR WASTE
8000 FOR J=0 TO 9
8010 FOR I=0 TO 9
8020 IF B%(I,J)=3 THEN B%(I,J)=0
8030 NEXT I
8040 NEXT J
8050 RETURN

9000 REM DO MOVE
9010 INPUT "YOU (X,Y)";X%,Y%
9020 IF B%(X%,Y%)<>0 THEN 2010
9030 B%(X%,Y%)=P%
9050 RETURN

10000 REM SCAN FOR REACTION
10010 FOR J=0 TO 9
10020 FOR I=0 TO 9
10030 FOR L=-1 TO 1
10040 FOR K=-1 TO 1
10050 IF K=0 AND L=0 THEN 10090
10060 X=I+K: Y=J+L
10070 IF X<0 OR X>9 OR Y<0 OR Y>9 THEN 10090
10080 IF B%(X,Y)=3 THEN B%(I,J)=3: GOTO 10110
10090 NEXT K
10100 NEXT L
10110 NEXT I
10120 NEXT J
10080 RETURN
