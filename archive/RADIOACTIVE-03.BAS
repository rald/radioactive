1000 REM RADIO ACTIVE
1010 DIM B%(9,9),SX%(99),SY%(99):SP%=100:PX%=0:PY%=0
1020 PRINT CHR$(147);"RADIOACTIVE"
1030 PRINT "PRESS ENTER KEY..."
1040 K=0
1050 K=K+1: GET A$: IF A$<>CHR$(13) THEN 1050
1060 T=RND(-K)
1065 GOSUB 3000
1070 P%=1:GOSUB 9000:GOSUB 3000:GOSUB 4000
1080 P%=2:GOSUB 2000:GOSUB 3000:GOSUB 4000
1090 P%=1:GOSUB 9000:GOSUB 3000:GOSUB 4000
1100 PX%=X%:PY%=Y%
1105 GOSUB 5000:GOSUB 10000:GOSUB 3000:GOSUB 4000
1106 GOSUB 8000:GOSUB 3000:GOSUB 4000
1110 P%=2:GOSUB 2000:GOSUB 3000:GOSUB 4000
1120 PX%=X%:PY%=Y%
1121 GOSUB 5000:GOSUB 10000:GOSUB 3000:GOSUB 4000
1122 GOSUB 8000:GOSUB 3000:GOSUB 4000
1130 GOTO 1090

2000 REM DO MOVE
2010 X%=INT(RND(1)*10)
2020 Y%=INT(RND(1)*10)
2030 IF B%(X%,Y%)<>0 THEN 2010
2040 B%(X%,Y%)=P%
2060 IF P%=2 THEN PRINT "CPU MOVE";X%;Y%: GOSUB 4000
2070 RETURN

3000 REM SHOW BOARD
3010 PRINT CHR$(147);"RADIOACTIVE";CHR$(13);" 0123456789"
3020 FOR J=0 TO 9
3030 PRINT MID$(STR$(J),2);
3040 FOR I=0 TO 9
3050 IF B%(I,J)=0 THEN PRINT ".";
3060 IF B%(I,J)=1 THEN PRINT "O";
3070 IF B%(I,J)=2 THEN PRINT "X";
3080 IF B%(I,J)=3 THEN PRINT "*";
3090 NEXT I
3100 PRINT
3110 NEXT J
3120 PRINT
3130 RETURN

4000 REM SLEEP
4010 FOR D=1 TO 1000:NEXT D
4020 RETURN

5000 REM PUSH
5010 SP%=SP%-1
5020 SX%(SP%)=PX%
5030 SY%(SP%)=PY%
5040 RETURN

6000 REM POP
6010 PX%=SX%(SP%)
6020 PY%=SY%(SP%)
6030 SP%=SP%+1
6040 RETURN

7000 REM CHAIN REACTION
7010 IF SP%=100 THEN RETURN: REM STACK IS EMPTY
7015 GOSUB 6000:I%=PX%:J%=PY%
7016 IF I%<0 OR I%>9 OR J%<0 OR J%>9 THEN RETURN
7018 IF B%(I%,J%)=3 THEN 7200: REM ALREADY EXPLODED, SKIP
7020 N%=0
7030 FOR L=-1 TO 1:FOR K=-1 TO 1
7050 IF K=0 AND L=0 THEN 7080
7060 X=I%+K:Y=J%+L
7065 IF X<0 OR X>9 OR Y<0 OR Y>9 THEN 7080
7070 IF B%(X,Y)<>0 THEN N%=N%+1 
7080 NEXT K:NEXT L
7090 IF N%<3 THEN 7150
7100 FOR L=-1 TO 1:FOR K=-1 TO 1
7110 X=I%+K:Y=J%+L
7120 IF X<0 OR X>9 OR Y<0 OR Y>9 THEN 7140
7130 IF B%(X,Y)=1 OR B%(X,Y)=2 THEN B%(X,Y)=3:PX%=X:PY%=Y:GOSUB 5000
7140 NEXT K:NEXT L
7150 IF SP%<100 THEN 7010: REM LOOP UNTIL STACK IS BACK TO 100
7160 RETURN

8000 REM CLEAR WASTE
8000 FOR J=0 TO 9
8010 FOR I=0 TO 9
8020 IF B%(I,J)=3 THEN B%(I,J)=0
8030 NEXT I
8040 NEXT J
8050 RETURN

9000 REM DO MOVE
9010 INPUT "YOU (X,Y)";X%,Y%
9020 IF B%(X%,Y%)<>0 THEN 2010
9030 B%(X%,Y%)=P%
9050 RETURN

10000 REM SCAN FOR REACTION
10000 FOR J=0 TO 9
10010 FOR I=0 TO 9
10040 PX%=X:PY%=Y:GOSUB 5000: GOSUB 7000
10050 NEXT I
10060 NEXT J
10070 RETURN
