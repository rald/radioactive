1000 REM RADIO ACTIVE
1010 DIM B%(9,9),SX%(99),SY%(99):SP%=100:PX%=0:PY%=0
1020 PRINT CHR$(147);"RADIOACTIVE"
1030 PRINT "PRESS ENTER KEY..."
1040 K=0
1050 K=K+1: GET A$: IF A$<>CHR$(13) THEN 1050
1060 T=RND(-K)
1070 GOSUB 3000
1080 P%=1:GOSUB 9000:GOSUB 3000:GOSUB 4000
1090 P%=2:GOSUB 2000:GOSUB 3000:GOSUB 4000
1100 P%=1:GOSUB 9000:GOSUB 3000:GOSUB 4000
1110 GOSUB 7000:GOSUB 10000:GOSUB 3000:GOSUB 4000
1120 GOSUB 8000:GOSUB 3000:GOSUB 4000
1130 P%=2:GOSUB 2000:GOSUB 3000:GOSUB 4000
1140 GOSUB 7000:GOSUB 10000:GOSUB 3000:GOSUB 4000
1150 GOSUB 8000:GOSUB 3000:GOSUB 4000
1160 GOTO 1100

2000 REM RANDOM MOVE
2010 X%=INT(RND(1)*10):Y%=INT(RND(1)*10)
2030 IF B%(X%,Y%)<>0 THEN 2010
2040 B%(X%,Y%)=P%
2050 IF P%=2 THEN PRINT "CPU MOVE";X%;",";Y%
2060 RETURN

3000 REM SHOW BOARD
3010 PRINT CHR$(147);"RADIOACTIVE";CHR$(13);" 0123456789"
3020 FOR J=0 TO 9:PRINT MID$(STR$(J),2);
3040 FOR I=0 TO 9
3050 IF B%(I,J)=0 THEN PRINT ".";
3060 IF B%(I,J)=1 THEN PRINT "O";
3070 IF B%(I,J)=2 THEN PRINT "X";
3080 IF B%(I,J)=3 THEN PRINT "*";
3090 NEXT I:PRINT:NEXT J:PRINT:RETURN

4000 REM SLEEP
4010 FOR D=1 TO 500:NEXT D:RETURN

7000 REM REACTION - OPTIMIZED
7010 FOR J=0 TO 9:L1=J-1:L2=J+1:IF L1<0 THEN L1=0
7015 IF L2>9 THEN L2=9
7020 FOR I=0 TO 9:K1=I-1:K2=I+1:IF K1<0 THEN K1=0
7025 IF K2>9 THEN K2=9
7030 N%=0:FOR L=L1 TO L2:FOR K=K1 TO K2
7040 IF B%(K,L)<>0 THEN N%=N%+1
7050 NEXT K:NEXT L
7060 IF N%>3 THEN B%(I,J)=3:REM N=4 INCL. SELF
7070 NEXT I:NEXT J:RETURN

8000 REM CLEAR WASTE
8010 FOR J=0 TO 9:FOR I=0 TO 9
8030 IF B%(I,J)=3 THEN B%(I,J)=0
8040 NEXT I:NEXT J:RETURN

9000 REM INPUT MOVE
9010 INPUT "YOU (X,Y)";X%,Y%
9020 IF X%<0 OR X%>9 OR Y%<0 OR Y%>9 THEN 9010
9025 IF B%(X%,Y%)<>0 THEN PRINT "OCCUPIED":GOTO 9010
9030 B%(X%,Y%)=P%:RETURN

10000 REM SCAN FOR REACTION - FAST SPREAD
10010 FOR J=0 TO 9:L1=J-1:L2=J+1:IF L1<0 THEN L1=0
10015 IF L2>9 THEN L2=9
10020 FOR I=0 TO 9:IF B%(I,J)=3 THEN 10070
10030 K1=I-1:K2=I+1:IF K1<0 THEN K1=0
10035 IF K2>9 THEN K2=9
10040 FOR L=L1 TO L2:FOR K=K1 TO K2
10050 IF B%(K,L)=3 THEN B%(I,J)=3:L=L2:K=K2
10060 NEXT K:NEXT L
10070 NEXT I:NEXT J:RETURN